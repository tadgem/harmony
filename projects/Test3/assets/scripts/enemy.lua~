local view = nil
local viewTransform = nil

function start()
    print("enemy.lua : start")
end

function GetView()
    if view == nil then
        view = harmony.GetView("RuntimeView")
        if view == nil then
            return
        end
        viewEntity = harmony.GetViewEntity(view)
        viewTransform = viewEntity:GetTransform()
    end
end

function update()
    GetView()
    deltaTime = time.GetFrameTime();
end

function cleanup()
    print("TestLua : Cleanup")
end